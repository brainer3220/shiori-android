<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="26dp"
    app:cardElevation="0dp"
    app:rippleColor="@color/shiori_surface"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="11dp"
        android:paddingEnd="8dp"
        android:paddingBottom="11dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/link_icon_container"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/shiori_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/shiori_line"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/link_favicon_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/link_icon_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:text="@string/label_link_icon_placeholder"
                    android:textColor="@color/shiori_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
            android:id="@+id/link_title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            android:maxLines="2"
            android:textColor="@color/shiori_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

            <TextView
                android:id="@+id/link_domain_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/shiori_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/link_summary_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:lineSpacingExtra="1dp"
                android:maxLines="2"
                android:textColor="@color/shiori_text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/link_status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/shiori_text_muted"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/link_timestamps_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/shiori_text_muted"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/link_overflow_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_muted_circle"
            android:contentDescription="@string/label_browser_menu"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_more"
            app:tint="@color/shiori_text_secondary" />

        <CheckBox
            android:id="@+id/link_select_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:contentDescription="@string/label_select_link"
                android:text=""
                android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/link_toggle_read_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_mark_read" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/link_edit_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_edit_link" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/link_delete_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_move_to_trash" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
