@@ -55,11 +55,32 @@ object ApiAccessInputValidator {
 
         return when (scheme) {
             "https" -> true
-            "http" -> host == "localhost" || host == "127.0.0.1" || host == "10.0.2.2"
+            "http" -> isLocalDevelopmentHost(host)
             else -> false
         }
